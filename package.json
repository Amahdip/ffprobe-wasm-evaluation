{
  "name": "ffprobe-test",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:analyze": "npm run build && node scripts/analyze-build-sizes.mjs",
    "analyze": "node scripts/analyze-build-sizes.mjs",
    "fixtures:generate": "bash scripts/compatibility/generate-fixtures.sh",
    "fixtures:generate:optional": "GENERATE_OPTIONAL=1 bash scripts/compatibility/generate-fixtures.sh",
    "fixtures:manifest": "node scripts/compatibility/write-fixture-manifest.mjs && cp compatibility/test-matrix.json public/compatibility/test-matrix.json",
    "fixtures:ensure": "node scripts/compatibility/ensure-core-fixtures.mjs",
    "samples:import-downloads": "bash scripts/compatibility/import-downloads.sh",
    "prebuild": "npm run fixtures:ensure && node scripts/copy-bench-summary.mjs",
    "build:deploy": "npm run build",
    "verify:deployment": "bash scripts/verify-deployment.sh",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "ffprobe-wasm": "0.3.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
