{
  "version": "1.0.0",
  "package": "ffprobe-wasm@0.3.1",
  "defaults": {
    "durationSeconds": 2,
    "width": 640,
    "height": 360,
    "fps": 30
  },
  "categories": [
    {
      "id": "format",
      "label": "Container formats",
      "description": "Baseline H.264 + AAC at 30 fps unless noted."
    },
    {
      "id": "video-codec",
      "label": "Video codecs",
      "description": "Codec detection across common containers."
    },
    {
      "id": "audio-codec",
      "label": "Audio codecs",
      "description": "Audio stream detection and codec naming."
    },
    {
      "id": "special",
      "label": "Special cases",
      "description": "Edge cases relevant to uploader preflight."
    },
    {
      "id": "real-world",
      "label": "Real-world samples",
      "description": "Actual upload files copied from Downloads or external sources."
    }
  ],
  "testCases": [
    {
      "id": "TC-FMT-001",
      "category": "format",
      "name": "MP4 container",
      "container": "mp4",
      "videoCodec": "h264",
      "audioCodec": "aac",
      "specialCase": null,
      "fixtureFile": "format/mp4-h264-aac-30fps.mp4",
      "expected": {
        "analyzeSuccess": true,
        "containerContains": "mp4",
        "videoCodec": "h264",
        "audioCodec": "aac",
        "fps": 30,
        "width": 640,
        "height": 360,
        "durationSeconds": 2,
        "hasAudio": true,
        "hasVideo": true
      },
      "browserNotes": "Baseline case; should work in all cross-origin-isolated browsers."
    },
    {
      "id": "TC-FMT-002",
      "category": "format",
      "name": "MOV container",
      "container": "mov",
      "videoCodec": "h264",
      "audioCodec": "aac",
      "specialCase": null,
      "fixtureFile": "format/mov-h264-aac-30fps.mov",
      "expected": {
        "analyzeSuccess": true,
        "containerContains": "mov",
        "videoCodec": "h264",
        "audioCodec": "aac",
        "fps": 30,
        "width": 640,
        "height": 360,
        "durationSeconds": 2,
        "hasAudio": true,
        "hasVideo": true
      },
      "browserNotes": "QuickTime/MOV is commonly uploaded from mobile devices."
    },
    {
      "id": "TC-FMT-003",
      "category": "format",
      "name": "WebM container",
      "container": "webm",
      "videoCodec": "vp9",
      "audioCodec": "opus",
      "specialCase": null,
      "fixtureFile": "format/webm-vp9-opus-30fps.webm",
      "expected": {
        "analyzeSuccess": true,
        "containerContains": "webm",
        "videoCodec": "vp9",
        "audioCodec": "opus",
        "fps": 30,
        "width": 640,
        "height": 360,
        "durationSeconds": 2,
        "hasAudio": true,
        "hasVideo": true
      },
      "browserNotes": "WebM support depends on bundled libav build; verify VP9/Opus detection."
    },
    {
      "id": "TC-FMT-004",
      "category": "format",
      "name": "MKV container",
      "container": "mkv",
      "videoCodec": "h264",
      "audioCodec": "aac",
      "specialCase": null,
      "fixtureFile": "format/mkv-h264-aac-30fps.mkv",
      "expected": {
        "analyzeSuccess": true,
        "containerContains": "matroska",
        "videoCodec": "h264",
        "audioCodec": "aac",
        "fps": 30,
        "width": 640,
        "height": 360,
        "durationSeconds": 2,
        "hasAudio": true,
        "hasVideo": true
      },
      "browserNotes": "Matroska support may be partial in older libav builds."
    },
    {
      "id": "TC-FMT-005",
